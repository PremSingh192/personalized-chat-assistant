            margin-bottom: 1rem;
            border: 1px solid #fcc;
        }
        .quick-links {
            text-align: center;
            margin-top: 1rem;
        }
        .quick-links a {
            color: #667eea;
            text-decoration: none;
            margin: 0 0.5rem;
            font-size: 0.9rem;
        }
        .quick-links a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h1>Login</h1>
            <p>Chat Widget Platform</p>
        </div>
        
        <% if (typeof error !== 'undefined') { %>
            <div class="error"><%= error %></div>
        <% } %>
        
        <form method="POST" action="/login">
            <div class="user-type-selector">
                <button type="button" class="user-type-btn active" data-type="admin">Admin</button>
                <button type="button" class="user-type-btn" data-type="business">Business</button>
            </div>
            
            <input type="hidden" id="userType" name="userType" value="admin">
            
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required>
            </div>
            
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required>
            </div>
            
            <button type="submit" class="login-btn">Login</button>
        </form>
        
        <div class="quick-links">
            <a href="/admin/login">Admin Login</a>
            <a href="/business/login">Business Login</a>
        </div>
    </div>

    <script>
        const userButtons = document.querySelectorAll('.user-type-btn');
        const userTypeInput = document.getElementById('userType');
        
        userButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                userButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                userTypeInput.value = btn.dataset.type;
            });
        });
        
        // Set initial user type from query parameter or form data
        const urlParams = new URLSearchParams(window.location.search);
        const userType = urlParams.get('type') || '<%= typeof userType !== "undefined" ? userType : "admin" %>';
        
        userButtons.forEach(btn => {
            if (btn.dataset.type === userType) {
                btn.click();
            }
        });
    </script>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chat Widget Platform</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .landing-container {
            text-align: center;
            color: white;
            max-width: 600px;
            padding: 2rem;
        }
        .landing-header {
            margin-bottom: 3rem;
        }
        .landing-header h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
            font-weight: 700;
        }
        .landing-header p {
            font-size: 1.2rem;
            opacity: 0.9;
            margin-bottom: 2rem;
        }
        .cta-button {
            background: white;
            color: #667eea;
            padding: 1rem 2rem;
            border: none;
            border-radius: 50px;
            font-size: 1.1rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-block;
            transition: transform 0.3s, box-shadow 0.3s;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }
        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        }
        .features {
            margin-top: 3rem;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 2rem;
        }
        .feature {
            background: rgba(255,255,255,0.1);
            padding: 1.5rem;
            border-radius: 10px;
            backdrop-filter: blur(10px);
        }
        .feature h3 {
            margin-bottom: 0.5rem;
            font-size: 1.1rem;
        }
        .feature p {
            opacity: 0.8;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <div class="landing-container">
        <div class="landing-header">
            <h1>Chat Widget Platform</h1>
            <p>Powerful AI-powered chat solutions for your business</p>
            <a href="/login" class="cta-button">Get Started</a>
        </div>
        
        <div class="features">
            <div class="feature">
                <h3>🤖 AI-Powered</h3>
                <p>Advanced AI responses for customer support</p>
            </div>
            <div class="feature">
                <h3>📊 Analytics</h3>
                <p>Detailed insights and conversation tracking</p>
            </div>
            <div class="feature">
                <h3>🎨 Customizable</h3>
                <p>Match your brand with custom styling</p>
            </div>
            <div class="feature">
                <h3>🔒 Secure</h3>
                <p>Enterprise-grade security and privacy</p>
            </div>
        </div>
    </div>
</body>
</html>
